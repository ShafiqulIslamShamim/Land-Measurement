<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
	xmlns:android="http://schemas.android.com/apk/res/android"
	xmlns:app="http://schemas.android.com/apk/res-auto"
	android:id="@+id/style_root" android:layout_width="match_parent"
	android:layout_height="match_parent"
	android:background="@color/style_dark_bg">

	<androidx.core.widget.NestedScrollView
		android:layout_width="match_parent"
		android:layout_height="match_parent" android:scrollbars="none"
		android:overScrollMode="never">

		<LinearLayout android:layout_width="match_parent"
			android:layout_height="wrap_content" android:orientation="vertical"
			android:paddingStart="20dp" android:paddingEnd="20dp"
			android:paddingTop="16dp" android:paddingBottom="48dp">

			<!-- Top Header Action Bar with Close Button -->
			<LinearLayout android:layout_width="match_parent"
				android:layout_height="56dp" android:orientation="horizontal"
				android:gravity="center_vertical" android:layout_marginBottom="20dp">

				<ImageButton android:id="@+id/btn_close"
					android:layout_width="40dp" android:layout_height="40dp"
					android:src="@drawable/ic_close"
					android:background="@drawable/bg_circle_button"
					app:tint="?attr/colorOnSurface" android:scaleType="centerInside"
					android:contentDescription="@string/style_close" />

				<TextView android:layout_width="wrap_content"
					android:layout_height="wrap_content"
					android:text="@string/style_title" android:textSize="24sp"
					android:textStyle="bold" android:textColor="?attr/colorOnSurface"
					android:layout_marginStart="16dp" />
			</LinearLayout>

			<!-- Gradient Illustration / Landscape Banner Card -->
			<com.google.android.material.card.MaterialCardView
				android:id="@+id/card_style_preview_container"
				android:layout_width="match_parent" android:layout_height="176dp"
				android:layout_marginBottom="24dp" app:cardCornerRadius="24dp"
				app:cardElevation="0dp" app:strokeWidth="1dp"
				app:strokeColor="@color/style_card_stroke"
				app:cardBackgroundColor="@color/style_card_bg">

				<FrameLayout android:layout_width="match_parent"
					android:layout_height="match_parent">

					<ImageView android:id="@+id/iv_style_preview"
						android:layout_width="match_parent"
						android:layout_height="match_parent"
						android:src="@drawable/ic_style_preview_vector"
						android:scaleType="fitCenter" android:padding="8dp" />

					<!-- Floating Badge indicating Current Active Scheme -->
					<com.google.android.material.card.MaterialCardView
						android:id="@+id/card_active_badge"
						android:layout_width="wrap_content"
						android:layout_height="wrap_content"
						android:layout_gravity="bottom|start" android:layout_margin="16dp"
						app:cardBackgroundColor="#B32C1917" app:cardCornerRadius="16dp"
						app:strokeWidth="0dp" app:cardElevation="0dp">

						<LinearLayout android:layout_width="wrap_content"
							android:layout_height="wrap_content"
							android:orientation="horizontal"
							android:gravity="center_vertical" android:paddingStart="12dp"
							android:paddingEnd="12dp" android:paddingTop="6dp"
							android:paddingBottom="6dp">

							<ImageView android:id="@+id/iv_active_badge_icon"
								android:layout_width="14dp" android:layout_height="14dp"
								android:src="@drawable/palette_24px" app:tint="#FFA08C" />

							<TextView android:id="@+id/tv_active_badge"
								android:layout_width="wrap_content"
								android:layout_height="wrap_content"
								android:text="@string/active_dynamic"
								android:textColor="#FFA08C" android:textSize="11sp"
								android:textStyle="bold" android:layout_marginStart="6dp" />
						</LinearLayout>
					</com.google.android.material.card.MaterialCardView>
				</FrameLayout>
			</com.google.android.material.card.MaterialCardView>

			<!-- Category: Accents & Schemes -->
			<TextView android:layout_width="wrap_content"
				android:layout_height="wrap_content"
				android:text="@string/accents_and_schemes" android:textSize="14sp"
				android:textStyle="bold" android:textColor="?attr/colorPrimary"
				android:letterSpacing="0.04" android:layout_marginBottom="12dp" />

			<!-- Single card encompassing Dynamic (Header) + Accents (Row) -->
			<com.google.android.material.card.MaterialCardView
				android:id="@+id/card_accents_container"
				android:layout_width="match_parent"
				android:layout_height="wrap_content"
				android:layout_marginBottom="28dp" app:cardCornerRadius="20dp"
				app:cardElevation="0dp" app:strokeWidth="1dp"
				app:strokeColor="@color/style_card_stroke"
				app:cardBackgroundColor="@color/style_card_bg">

				<LinearLayout android:layout_width="match_parent"
					android:layout_height="wrap_content" android:orientation="vertical">

					<!-- Row 1: Dynamic Option -->
					<LinearLayout android:id="@+id/card_dynamic_theme"
						android:layout_width="match_parent" android:layout_height="56dp"
						android:orientation="horizontal" android:gravity="center_vertical"
						android:paddingStart="16dp" android:paddingEnd="16dp"
						android:clickable="true" android:focusable="true"
						android:background="?attr/selectableItemBackground">

						<ImageView android:id="@+id/iv_dynamic_checked"
							android:layout_width="22dp" android:layout_height="22dp"
							android:src="@drawable/ic_check" app:tint="?attr/colorPrimary"
							android:visibility="visible" />

						<ImageView android:layout_width="22dp"
							android:layout_height="22dp" android:src="@drawable/palette_24px"
							app:tint="?attr/colorPrimary" android:layout_marginStart="12dp" />

						<TextView android:layout_width="wrap_content"
							android:layout_height="wrap_content"
							android:text="@string/dynamic_color_theme"
							android:textSize="15sp" android:textStyle="bold"
							android:textColor="?attr/colorOnSurface"
							android:layout_marginStart="12dp" />
					</LinearLayout>

					<!-- Thin Divider -->
					<View android:layout_width="match_parent"
						android:layout_height="1dp"
						android:background="@color/style_card_stroke"
						android:layout_marginStart="16dp" android:layout_marginEnd="16dp" />

					<!-- Row 2: Grid/Row of Accent Selections -->
					<LinearLayout android:layout_width="match_parent"
						android:layout_height="wrap_content"
						android:orientation="horizontal" android:gravity="center_vertical"
						android:paddingTop="20dp" android:paddingBottom="20dp"
						android:paddingStart="8dp" android:paddingEnd="8dp">

						<!-- Emerald -->
						<LinearLayout android:id="@+id/btn_accent_emerald"
							android:layout_width="0dp" android:layout_height="wrap_content"
							android:layout_weight="1" android:orientation="vertical"
							android:gravity="center" android:clickable="true"
							android:focusable="true"
							android:background="?attr/selectableItemBackgroundBorderless">

							<FrameLayout android:layout_width="48dp"
								android:layout_height="48dp">
								<View android:layout_width="40dp"
									android:layout_height="40dp" android:layout_gravity="center"
									android:background="@drawable/ic_accent_emerald" />
								<ImageView android:id="@+id/iv_accent_emerald_check"
									android:layout_width="18dp" android:layout_height="18dp"
									android:layout_gravity="center"
									android:src="@drawable/ic_check" app:tint="#FFFFFF"
									android:visibility="gone" />
							</FrameLayout>

							<TextView android:layout_width="wrap_content"
								android:layout_height="wrap_content"
								android:text="@string/accent_emerald" android:textSize="12sp"
								android:textStyle="normal" android:layout_marginTop="6dp"
								android:textColor="?attr/colorOnSurfaceVariant" />
						</LinearLayout>

						<!-- Blossom -->
						<LinearLayout android:id="@+id/btn_accent_blossom"
							android:layout_width="0dp" android:layout_height="wrap_content"
							android:layout_weight="1" android:orientation="vertical"
							android:gravity="center" android:clickable="true"
							android:focusable="true"
							android:background="?attr/selectableItemBackgroundBorderless">

							<FrameLayout android:layout_width="48dp"
								android:layout_height="48dp">
								<View android:layout_width="40dp"
									android:layout_height="40dp" android:layout_gravity="center"
									android:background="@drawable/ic_accent_blossom" />
								<ImageView android:id="@+id/iv_accent_blossom_check"
									android:layout_width="18dp" android:layout_height="18dp"
									android:layout_gravity="center"
									android:src="@drawable/ic_check" app:tint="#FFFFFF"
									android:visibility="gone" />
							</FrameLayout>

							<TextView android:layout_width="wrap_content"
								android:layout_height="wrap_content"
								android:text="@string/accent_blossom" android:textSize="12sp"
								android:textStyle="normal" android:layout_marginTop="6dp"
								android:textColor="?attr/colorOnSurfaceVariant" />
						</LinearLayout>

						<!-- Ocean -->
						<LinearLayout android:id="@+id/btn_accent_ocean"
							android:layout_width="0dp" android:layout_height="wrap_content"
							android:layout_weight="1" android:orientation="vertical"
							android:gravity="center" android:clickable="true"
							android:focusable="true"
							android:background="?attr/selectableItemBackgroundBorderless">

							<FrameLayout android:layout_width="48dp"
								android:layout_height="48dp">
								<View android:layout_width="40dp"
									android:layout_height="40dp" android:layout_gravity="center"
									android:background="@drawable/ic_accent_ocean" />
								<ImageView android:id="@+id/iv_accent_ocean_check"
									android:layout_width="18dp" android:layout_height="18dp"
									android:layout_gravity="center"
									android:src="@drawable/ic_check" app:tint="#FFFFFF"
									android:visibility="gone" />
							</FrameLayout>

							<TextView android:layout_width="wrap_content"
								android:layout_height="wrap_content"
								android:text="@string/accent_ocean" android:textSize="12sp"
								android:textStyle="normal" android:layout_marginTop="6dp"
								android:textColor="?attr/colorOnSurfaceVariant" />
						</LinearLayout>

						<!-- Amber -->
						<LinearLayout android:id="@+id/btn_accent_amber"
							android:layout_width="0dp" android:layout_height="wrap_content"
							android:layout_weight="1" android:orientation="vertical"
							android:gravity="center" android:clickable="true"
							android:focusable="true"
							android:background="?attr/selectableItemBackgroundBorderless">

							<FrameLayout android:layout_width="48dp"
								android:layout_height="48dp">
								<View android:layout_width="40dp"
									android:layout_height="40dp" android:layout_gravity="center"
									android:background="@drawable/ic_accent_amber" />
								<ImageView android:id="@+id/iv_accent_amber_check"
									android:layout_width="18dp" android:layout_height="18dp"
									android:layout_gravity="center"
									android:src="@drawable/ic_check" app:tint="#FFFFFF"
									android:visibility="gone" />
							</FrameLayout>

							<TextView android:layout_width="wrap_content"
								android:layout_height="wrap_content"
								android:text="@string/accent_amber" android:textSize="12sp"
								android:textStyle="normal" android:layout_marginTop="6dp"
								android:textColor="?attr/colorOnSurfaceVariant" />
						</LinearLayout>

						<!-- Coral -->
						<LinearLayout android:id="@+id/btn_accent_coral"
							android:layout_width="0dp" android:layout_height="wrap_content"
							android:layout_weight="1" android:orientation="vertical"
							android:gravity="center" android:clickable="true"
							android:focusable="true"
							android:background="?attr/selectableItemBackgroundBorderless">

							<FrameLayout android:layout_width="48dp"
								android:layout_height="48dp">
								<View android:layout_width="40dp"
									android:layout_height="40dp" android:layout_gravity="center"
									android:background="@drawable/ic_accent_coral" />
								<ImageView android:id="@+id/iv_accent_coral_check"
									android:layout_width="18dp" android:layout_height="18dp"
									android:layout_gravity="center"
									android:src="@drawable/ic_check" app:tint="#FFFFFF"
									android:visibility="gone" />
							</FrameLayout>

							<TextView android:layout_width="wrap_content"
								android:layout_height="wrap_content"
								android:text="@string/accent_coral" android:textSize="12sp"
								android:textStyle="normal" android:layout_marginTop="6dp"
								android:textColor="?attr/colorOnSurfaceVariant" />
						</LinearLayout>
					</LinearLayout>
				</LinearLayout>
			</com.google.android.material.card.MaterialCardView>

			<!-- Category: Preferred Theme Mode -->
			<TextView android:layout_width="wrap_content"
				android:layout_height="wrap_content"
				android:text="@string/preferred_theme_mode" android:textSize="14sp"
				android:textStyle="bold" android:textColor="?attr/colorPrimary"
				android:letterSpacing="0.04" android:layout_marginBottom="12dp" />

			<!-- Concentric Segmented Button Row container with 4dp padding -->
			<LinearLayout android:id="@+id/container_segmented"
				android:layout_width="match_parent" android:layout_height="48dp"
				android:orientation="horizontal"
				android:background="@drawable/segmented_button_border"
				android:padding="4dp" android:layout_marginBottom="28dp">

				<TextView android:id="@+id/btn_theme_system"
					android:layout_width="0dp" android:layout_height="match_parent"
					android:layout_weight="1" android:gravity="center"
					android:text="@string/theme_system" android:textStyle="bold"
					android:textSize="14sp" android:clickable="true"
					android:focusable="true" android:textColor="@color/style_text_mute"
					android:background="@android:color/transparent" />

				<TextView android:id="@+id/btn_theme_light"
					android:layout_width="0dp" android:layout_height="match_parent"
					android:layout_weight="1" android:gravity="center"
					android:text="@string/theme_light" android:textStyle="bold"
					android:textSize="14sp" android:clickable="true"
					android:focusable="true" android:textColor="@color/style_text_mute"
					android:background="@android:color/transparent" />

				<TextView android:id="@+id/btn_theme_dark"
					android:layout_width="0dp" android:layout_height="match_parent"
					android:layout_weight="1" android:gravity="center"
					android:text="@string/theme_dark" android:textStyle="bold"
					android:textSize="14sp" android:clickable="true"
					android:focusable="true" android:textColor="@color/style_text_mute"
					android:background="@android:color/transparent" />
			</LinearLayout>

			<!-- AMOLED Option Card -->
			<com.google.android.material.card.MaterialCardView
				android:id="@+id/card_amoled_black"
				android:layout_width="match_parent"
				android:layout_height="wrap_content" app:cardCornerRadius="20dp"
				app:cardElevation="0dp" app:strokeWidth="1dp"
				app:strokeColor="@color/style_card_stroke"
				app:cardBackgroundColor="@color/style_card_bg"
				android:clickable="true" android:focusable="true"
				android:foreground="?attr/selectableItemBackground">

				<LinearLayout android:layout_width="match_parent"
					android:layout_height="wrap_content"
					android:orientation="horizontal" android:gravity="center_vertical"
					android:paddingTop="18dp" android:paddingBottom="18dp"
					android:paddingStart="20dp" android:paddingEnd="20dp">

					<LinearLayout android:layout_width="0dp"
						android:layout_height="wrap_content" android:layout_weight="1"
						android:orientation="vertical">

						<TextView android:layout_width="wrap_content"
							android:layout_height="wrap_content"
							android:text="@string/amoled_black_mode" android:textSize="15sp"
							android:textStyle="bold" android:textColor="?attr/colorOnSurface" />

						<TextView android:layout_width="wrap_content"
							android:layout_height="wrap_content"
							android:text="@string/amoled_description" android:textSize="12sp"
							android:textColor="?attr/colorOnSurfaceVariant"
							android:layout_marginTop="6dp" />
					</LinearLayout>

					<com.google.android.material.materialswitch.MaterialSwitch
						android:id="@+id/switch_amoled"
						android:layout_width="wrap_content"
						android:layout_height="wrap_content" android:clickable="false"
						android:focusable="false" />
				</LinearLayout>
			</com.google.android.material.card.MaterialCardView>

		</LinearLayout>
	</androidx.core.widget.NestedScrollView>
</androidx.coordinatorlayout.widget.CoordinatorLayout>